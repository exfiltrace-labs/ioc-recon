    {
      "id": "team-nvd",
      "name": "NVD (CVE)",
      "category": "Vuln",
      "method": "GET",
      "url": "https://nvd.nist.gov/vuln/detail/%s",
      "encoding": "url",
      "refang": false,
      "types": ["cve"]
    },
    {
      "id": "team-mitre-attack",
      "name": "MITRE ATT&CK",
      "category": "Threat Intel",
      "method": "GET",
      "url": "https://attack.mitre.org/techniques/%s/",
      "encoding": "none",
      "refang": false,
      "types": ["any"],
      "match": { "pattern": "^T\\d{4}(\\.\\d{3})?$", "flags": "i" },
      "transform": [{ "pattern": "\\.", "replacement": "/" }]
    },
    {
      "id": "team-internal-soar",
      "name": "Internal SOAR - create case (example POST)",
      "category": "Internal",
      "method": "POST",
      "url": "https://soar.example.com/api/cases/search",
      "body": "indicator=%s&source=ioc-recon",
      "contentType": "application/x-www-form-urlencoded",
      "encoding": "none",
      "refang": true,
      "types": ["any"]
    }
